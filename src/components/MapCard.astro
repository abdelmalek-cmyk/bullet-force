---
interface Props {
  name: string;
  slug: string;
  size: string;
  bestMode: string;
  description: string;
}
const { name, slug, size, bestMode, description } = Astro.props;
---

<a
  href={`/maps/${slug}`}
  class="group block bg-bf-surface border border-bf-border rounded-xl overflow-hidden hover:border-bf-orange transition-all duration-200"
>
  <div class="aspect-video bg-gradient-to-br from-bf-surface-2 to-bf-darker flex items-center justify-center relative">
    <svg xmlns="http://www.w3.org/2000/svg" class="w-10 h-10 text-gray-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7"/>
    </svg>
    <div class="absolute top-2 left-2">
      <span class="text-xs bg-bf-darker/80 text-gray-300 px-2 py-0.5 rounded border border-bf-border">{size}</span>
    </div>
  </div>
  <div class="p-4">
    <h3 class="font-bold text-white group-hover:text-bf-orange transition-colors mb-1">{name}</h3>
    <p class="text-xs text-gray-400 mb-2">Best: {bestMode}</p>
    <p class="text-sm text-gray-300 line-clamp-2">{description}</p>
  </div>
</a>
