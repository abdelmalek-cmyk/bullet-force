---
export interface FAQItem {
  question: string;
  answer: string;
}
interface Props {
  items: FAQItem[];
  id?: string;
  schema?: boolean;
}
const { items, id, schema = true } = Astro.props;

const faqSchema = schema ? {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": items.map(({ question, answer }) => ({
    "@type": "Question",
    "name": question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": answer.replace(/<[^>]+>/g, ''),
    },
  })),
} : null;
---

{faqSchema && <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />}

<div {id} class="space-y-2.5">
  {items.map((item) => (
    <details class="group bg-bf-surface border border-bf-border rounded-xl">
      <summary class="flex items-center justify-between gap-4 px-5 py-4 cursor-pointer list-none select-none">
        <span class="font-medium text-gray-100 text-sm leading-relaxed">{item.question}</span>
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-gray-400 flex-shrink-0 transition-transform duration-200 group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
        </svg>
      </summary>
      <div class="px-5 pb-5 pt-3 border-t border-bf-border text-sm text-gray-300 leading-relaxed">
        <Fragment set:html={item.answer} />
      </div>
    </details>
  ))}
</div>
