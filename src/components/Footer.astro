---
const year = new Date().getFullYear();

const cols = [
  {
    title: 'Game',
    links: [
      { href: '/',         label: 'Home' },
      { href: '/play',     label: 'Play Online' },
      { href: '/unblocked',label: 'Play Unblocked' },
      { href: '/download', label: 'Download' },
      { href: '/mobile',   label: 'Mobile (Android & iOS)' },
    ],
  },
  {
    title: 'Guides',
    links: [
      { href: '/guides/how-to-play',        label: 'How to Play' },
      { href: '/guides/controls',           label: 'Controls & Keybinds' },
      { href: '/guides/scorestreaks',       label: 'Scorestreaks & UAV' },
      { href: '/guides/gold-credits',       label: 'Gold & Credits' },
      { href: '/guides/controller-support', label: 'Controller Support' },
    ],
  },
  {
    title: 'Content',
    links: [
      { href: '/weapons',       label: 'Weapons Tier List' },
      { href: '/maps',          label: 'All Maps' },
      { href: '/skins',         label: 'Skins & Cosmetics' },
      { href: '/updates',       label: 'Updates & Patch Notes' },
      { href: '/similar-games', label: 'Similar Games' },
    ],
  },
  {
    title: 'Info',
    links: [
      { href: '/faq',       label: 'FAQ' },
      { href: '/about',     label: 'About Bullet Force' },
      { href: '/account',   label: 'Account & Login' },
      { href: '/community', label: 'Community & Discord' },
    ],
  },
];
---

<footer class="bg-bf-darker border-t border-bf-border mt-20">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-12 pb-8">
    <div class="grid grid-cols-2 md:grid-cols-4 lg:grid-cols-5 gap-8">

      <!-- Brand -->
      <div class="col-span-2 md:col-span-4 lg:col-span-1">
        <a href="/" class="inline-flex items-center gap-2 font-extrabold text-xl mb-3">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-bf-orange" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="3 11 22 2 13 21 11 13 3 11"/></svg>
          <span class="text-white">Bullet<span class="text-bf-orange">Force</span></span>
        </a>
        <p class="text-sm text-gray-400 leading-relaxed">
          Free multiplayer FPS by Blayze Games. Play in your browser — no download needed.
        </p>
        <a href="/play" class="mt-4 inline-flex items-center gap-1.5 bg-bf-orange hover:bg-bf-orange-dark text-white text-sm font-bold px-4 py-2 rounded-lg transition-colors">
          Play Free Now
        </a>
      </div>

      {cols.map(col => (
        <div>
          <h3 class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-3">{col.title}</h3>
          <ul class="space-y-2">
            {col.links.map(({ href, label }) => (
              <li><a href={href} class="text-sm text-gray-500 hover:text-gray-200 transition-colors">{label}</a></li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <div class="border-t border-bf-border mt-10 pt-6 flex flex-col sm:flex-row items-center justify-between gap-3 text-xs text-gray-600">
      <p>&copy; {year} BulletForce.io — Fan site. Bullet Force is a trademark of Blayze Games / Lucas Wilde.</p>
      <p>Built with Astro SSG · Tailwind CSS</p>
    </div>
  </div>
</footer>
