    <p style="font-size:0.875rem; color:#9ca3af; margin-bottom:0.75rem;">Related guides:</p>
    <div style="display:flex; flex-wrap:wrap; gap:0.5rem;">
      <a href="/weapons" style="font-size:0.8125rem; color:#f97316; border:1px solid #2a2a38; border-radius:0.5rem; padding:0.375rem 0.75rem;">Weapons & Unlock Costs</a>
      <a href="/skins" style="font-size:0.8125rem; color:#f97316; border:1px solid #2a2a38; border-radius:0.5rem; padding:0.375rem 0.75rem;">Skins & Cosmetics Guide</a>
      <a href="/account" style="font-size:0.8125rem; color:#f97316; border:1px solid #2a2a38; border-radius:0.5rem; padding:0.375rem 0.75rem;">Account Guide (Save Progress)</a>
      <a href="/guides/how-to-play" style="font-size:0.8125rem; color:#f97316; border:1px solid #2a2a38; border-radius:0.5rem; padding:0.375rem 0.75rem;">How to Play Guide</a>
    </div>
  </div>
</GuideLayout>
