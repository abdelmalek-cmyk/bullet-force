  "name": "How to Use a Controller in Bullet Force on PC",
  "step": [
    { "@type": "HowToStep", "name": "Connect your controller", "text": "Plug your Xbox or PS4 controller into your PC via USB, or pair it via Bluetooth in Windows Bluetooth settings." },
