  { id: 'answer',    label: 'Does BF Support Controllers?' },
  { id: 'setup',     label: 'Controller Setup Steps' },
  { id: 'xbox',      label: 'Xbox Controller' },
  { id: 'ps4-ps5',   label: 'PS4 / PS5 Controller' },
  { id: 'tips',      label: 'Controller Tips' },
