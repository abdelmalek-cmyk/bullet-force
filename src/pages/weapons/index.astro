---
import BaseLayout from '../../layouts/BaseLayout.astro';
import WeaponCard from '../../components/WeaponCard.astro';
import FAQAccordion from '../../components/FAQAccordion.astro';
import { weapons } from '../../data/weapons';

const byTier = {
  S: weapons.filter(w => w.tier === 'S'),
  A: weapons.filter(w => w.tier === 'A'),
  B: weapons.filter(w => w.tier === 'B'),
  C: weapons.filter(w => w.tier === 'C'),
};

const faq = [
  {
    question: "What is the best gun in Bullet Force?",
    answer: "The <strong>M4A1</strong> is the best all-round gun in Bullet Force. It has balanced damage (38), high fire rate (75), and low recoil — effective at every range and for every playstyle. For close range, the <strong>P90</strong> is superior. For sniping, the <strong>M40A5</strong> is the top pick.",
  },
  {
    question: "What does a suppressor do in Bullet Force?",
    answer: "A suppressor in Bullet Force reduces muzzle flash, lowers gunshot audio (making it harder for enemies to locate you by sound), and removes your shots from enemy minimaps. The trade-off is a small reduction in effective range and slightly reduced muzzle velocity. Suppressors are best paired with the Ghost perk for true stealth builds.",
  },
  {
    question: "What does a muzzle brake do in Bullet Force?",
    answer: "A muzzle brake in Bullet Force reduces weapon recoil, particularly vertical recoil during sustained fire. This is most useful on high-recoil weapons like the AK-12 or heavy ARs. The trade-off is slightly increased muzzle flash and gunshot volume compared to a suppressor.",
  },
  {
    question: "Does a laser sight help sniping in Bullet Force?",
    answer: "A laser sight in Bullet Force improves hip fire accuracy — the visible laser beam tightens your bullet spread when firing without aiming down sights. It does not improve scoped accuracy. For snipers, a laser sight is generally less useful than a higher-magnification scope or suppressor.",
  },
  {
    question: "Can you get guns from Bullet Force cases?",
    answer: "No. Bullet Force cases (loot boxes) contain only cosmetic items — weapon skins and character cosmetics. Weapons themselves are unlocked by spending Credits (earned through gameplay). You cannot get weapon unlocks from cases.",
  },
];

const schema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": "Bullet Force Weapons Tier List",
  "description": "All Bullet Force weapons ranked by tier with stats, attachments, and unlock costs.",
  "itemListElement": weapons.map((w, i) => ({
    "@type": "ListItem",
    "position": i + 1,
    "name": w.name,
    "url": `https://bulletforce.io/weapons/${w.slug}`,
  })),
};
---

<BaseLayout
  title="Bullet Force Weapons – Best Guns, Stats & Tier List (2025)"
  description="Complete Bullet Force weapons guide. Best guns ranked by category, weapon stats, attachments, and which guns to unlock first."
  schema={schema}
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <h1 class="text-4xl sm:text-5xl font-black text-white mb-3">
      Bullet Force Weapons –<br />
      <span class="text-bf-orange">All Guns, Stats & Best Tier List</span>
    </h1>
    <p class="text-gray-300 text-lg leading-relaxed mb-10 max-w-2xl">
      Complete <strong class="text-white">Bullet Force weapons</strong> guide — every gun ranked by tier, with stats, best use cases, attachments, and unlock costs. Find the <strong class="text-white">best guns in Bullet Force</strong> for your playstyle.
    </p>

    <!-- Attachments explained quick ref -->
    <div class="grid sm:grid-cols-3 gap-4 mb-12 p-5 bg-bf-surface border border-bf-border rounded-2xl">
      <div>
        <h3 class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-2">Suppressor</h3>
        <p class="text-xs text-gray-300">Hides shots from minimap, reduces audio. Slight range reduction. Best for Ghost perk builds.</p>
      </div>
      <div>
        <h3 class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-2">Muzzle Brake</h3>
        <p class="text-xs text-gray-300">Reduces vertical recoil for sustained fire. Best on high-recoil weapons like AK-12.</p>
      </div>
      <div>
        <h3 class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-2">Laser Sight</h3>
        <p class="text-xs text-gray-300">Improves hip fire accuracy. Best for SMG close-quarters builds. Not useful for sniping.</p>
      </div>
    </div>

    <!-- S Tier -->
    {Object.entries(byTier).filter(([, arr]) => arr.length > 0).map(([tier, tierWeapons]) => (
      <section class="mb-10">
        <div class="flex items-center gap-3 mb-5">
          <span class={`text-sm font-bold px-3 py-1 rounded border ${
            tier === 'S' ? 'bg-yellow-500/20 text-yellow-400 border-yellow-500/30' :
            tier === 'A' ? 'bg-green-500/20 text-green-400 border-green-500/30' :
            tier === 'B' ? 'bg-blue-500/20 text-blue-400 border-blue-500/30' :
            'bg-gray-500/20 text-gray-400 border-gray-500/30'
          }`}>{tier} Tier</span>
          <span class="text-sm text-gray-400">{
            tier === 'S' ? 'Best-in-class — unlock these first' :
            tier === 'A' ? 'Excellent — strong in the right situation' :
            tier === 'B' ? 'Solid — good early game options' :
            'Average — outclassed by higher tiers'
          }</span>
        </div>
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-4">
          {tierWeapons.map(w => (
            <WeaponCard
              name={w.name}
              slug={w.slug}
              category={w.category}
              damage={w.damage}
              fireRate={w.fireRate}
              range={w.range}
              tier={w.tier}
            />
          ))}
        </div>
      </section>
    ))}

    <!-- By category best picks -->
    <section class="mt-12 bg-bf-surface border border-bf-border rounded-2xl p-6">
      <h2 class="text-2xl font-bold text-white mb-5">Best Gun Per Category</h2>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {[
          { cat: 'Best Assault Rifle', gun: 'M4A1', why: 'Balanced stats, low recoil, effective at all ranges.' },
          { cat: 'Best SMG',           gun: 'P90',  why: '90 fire rate + 50 mag = dominates close quarters.' },
          { cat: 'Best Sniper',        gun: 'M40A5',why: 'Near one-shot potential at very long range.' },
          { cat: 'Best for Stealth',   gun: 'AS VAL',why: 'Built-in suppressor + high damage per bullet.' },
          { cat: 'Best Budget AR',     gun: 'AK-12', why: 'High damage for 4,500 credits — strong medium range.' },
          { cat: 'Best for Beginners', gun: 'MPX',  why: 'Cheap, controllable, teaches the SMG playstyle.' },
        ].map(({ cat, gun, why }) => (
          <div class="bg-bf-darker border border-bf-border rounded-xl p-4">
            <div class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-1">{cat}</div>
            <div class="font-bold text-white text-lg mb-1">{gun}</div>
            <p class="text-xs text-gray-400">{why}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- Master unlock table -->
    <section class="mt-10">
      <h2 class="text-2xl font-bold text-white mb-5">All Bullet Force Weapons – Stats Table</h2>
      <div class="overflow-x-auto rounded-xl border border-bf-border">
        <table class="w-full text-sm">
          <thead class="bg-bf-surface">
            <tr>
              <th class="text-left text-xs font-semibold text-gray-400 uppercase tracking-wider px-4 py-3">Weapon</th>
              <th class="text-left text-xs font-semibold text-gray-400 uppercase tracking-wider px-4 py-3">Category</th>
              <th class="text-left text-xs font-semibold text-gray-400 uppercase tracking-wider px-4 py-3">Damage</th>
              <th class="text-left text-xs font-semibold text-gray-400 uppercase tracking-wider px-4 py-3">Fire Rate</th>
              <th class="text-left text-xs font-semibold text-gray-400 uppercase tracking-wider px-4 py-3">Range</th>
              <th class="text-left text-xs font-semibold text-gray-400 uppercase tracking-wider px-4 py-3">Unlock Cost</th>
              <th class="text-left text-xs font-semibold text-gray-400 uppercase tracking-wider px-4 py-3">Tier</th>
            </tr>
          </thead>
          <tbody>
            {weapons.map(w => (
              <tr class="border-t border-bf-border hover:bg-bf-surface/50 transition-colors">
                <td class="px-4 py-3 font-semibold text-white">
                  <a href={`/weapons/${w.slug}`} class="hover:text-bf-orange transition-colors">{w.name}</a>
                </td>
                <td class="px-4 py-3 text-gray-300">{w.category}</td>
                <td class="px-4 py-3 text-gray-300">{w.damage}</td>
                <td class="px-4 py-3 text-gray-300">{w.fireRate}</td>
                <td class="px-4 py-3 text-gray-300">{w.range}</td>
                <td class="px-4 py-3 text-gray-300">{w.unlockCost}</td>
                <td class="px-4 py-3">
                  <span class={`text-xs font-bold px-2 py-0.5 rounded ${
                    w.tier === 'S' ? 'bg-yellow-500/20 text-yellow-400' :
                    w.tier === 'A' ? 'bg-green-500/20 text-green-400' :
                    w.tier === 'B' ? 'bg-blue-500/20 text-blue-400' :
                    'bg-gray-500/20 text-gray-400'
                  }`}>{w.tier}</span>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>

    <!-- FAQ -->
    <section class="mt-12">
      <h2 class="text-2xl font-bold text-white mb-6">Bullet Force Weapons – FAQ</h2>
      <FAQAccordion items={faq} />
    </section>

    <!-- Related links -->
    <div class="mt-10 flex flex-wrap gap-3">
      <a href="/guides/gold-credits" class="text-sm text-bf-orange hover:underline border border-bf-border rounded-lg px-3 py-1.5">How to Earn Credits (Unlock Weapons)</a>
      <a href="/guides/how-to-play" class="text-sm text-bf-orange hover:underline border border-bf-border rounded-lg px-3 py-1.5">Beginner's Guide</a>
      <a href="/maps" class="text-sm text-bf-orange hover:underline border border-bf-border rounded-lg px-3 py-1.5">Maps (Best Weapons Per Map)</a>
    </div>
  </div>
</BaseLayout>
