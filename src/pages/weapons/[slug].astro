---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import { weapons } from '../../data/weapons';

export function getStaticPaths() {
  return weapons.map(w => ({ params: { slug: w.slug }, props: { weapon: w } }));
}

const { weapon } = Astro.props;

const tierLabel = {
  S: 'S-Tier — Best in Class',
  A: 'A-Tier — Excellent',
  B: 'B-Tier — Solid Pick',
  C: 'C-Tier — Situational',
} as const;

const tierColor = {
  S: 'text-yellow-400 bg-yellow-500/10 border-yellow-500/20',
  A: 'text-green-400 bg-green-500/10 border-green-500/20',
  B: 'text-blue-400 bg-blue-500/10 border-blue-500/20',
  C: 'text-gray-400 bg-gray-500/10 border-gray-500/20',
} as const;

const others = weapons.filter(w => w.slug !== weapon.slug && w.category === weapon.category).slice(0, 3);
---

<BaseLayout
  title={`${weapon.name} – Bullet Force ${weapon.category} Stats, Attachments & Guide`}
  description={`${weapon.name} in Bullet Force: damage ${weapon.damage}, fire rate ${weapon.fireRate}, range ${weapon.range}. Best attachments, tier rating, and unlock cost: ${weapon.unlockCost}.`}
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
    <Breadcrumb items={[{ label: 'Weapons', href: '/weapons' }, { label: weapon.name }]} />

    <div class="grid lg:grid-cols-3 gap-8">
      <!-- Main content -->
      <div class="lg:col-span-2">
        <div class="flex flex-wrap items-center gap-3 mb-3">
          <h1 class="text-4xl font-black text-white">{weapon.name}</h1>
          <span class={`text-sm font-bold px-3 py-1 rounded border ${tierColor[weapon.tier]}`}>
            {tierLabel[weapon.tier]}
          </span>
        </div>
        <p class="text-bf-orange font-medium mb-6">{weapon.category}</p>

        <p class="text-gray-300 leading-relaxed text-base mb-6">{weapon.description}</p>

        <!-- Stats -->
        <div class="bg-bf-surface border border-bf-border rounded-2xl p-5 mb-6">
          <h2 class="font-semibold text-white mb-4">Weapon Stats</h2>
          <div class="space-y-4">
            {[
              { label: 'Damage',    value: weapon.damage,    max: 100 },
              { label: 'Fire Rate', value: weapon.fireRate,  max: 100 },
            ].map(({ label, value, max }) => (
              <div>
                <div class="flex justify-between text-sm mb-1.5">
                  <span class="text-gray-400">{label}</span>
                  <span class="text-white font-semibold">{value}</span>
                </div>
                <div class="stat-bar">
                  <div class="stat-bar-fill" style={`width:${(value / max) * 100}%`}></div>
                </div>
              </div>
            ))}
            <div class="grid grid-cols-2 gap-4 pt-2">
              <div>
                <div class="text-xs text-gray-400 uppercase tracking-wider mb-1">Range</div>
                <div class="text-sm font-semibold text-white">{weapon.range}</div>
              </div>
              <div>
                <div class="text-xs text-gray-400 uppercase tracking-wider mb-1">Unlock Cost</div>
                <div class="text-sm font-semibold text-white">{weapon.unlockCost}</div>
              </div>
            </div>
          </div>
        </div>

        <!-- Best for -->
        <div class="bg-bf-surface border border-bf-border rounded-xl p-5 mb-6">
          <h2 class="font-semibold text-white mb-2">Best For</h2>
          <p class="text-sm text-gray-300">{weapon.bestFor}</p>
        </div>

        <!-- Pros & Cons -->
        <div class="grid sm:grid-cols-2 gap-4 mb-6">
          <div class="bg-bf-surface border border-green-500/20 rounded-xl p-4">
            <h3 class="font-semibold text-green-400 text-sm mb-3">Pros</h3>
            <ul class="space-y-2">
              {weapon.pros.map(p => (
                <li class="flex items-start gap-2 text-xs text-gray-300">
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5 text-green-400 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                  {p}
                </li>
              ))}
            </ul>
          </div>
          <div class="bg-bf-surface border border-red-500/20 rounded-xl p-4">
            <h3 class="font-semibold text-red-400 text-sm mb-3">Cons</h3>
            <ul class="space-y-2">
              {weapon.cons.map(c => (
                <li class="flex items-start gap-2 text-xs text-gray-300">
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5 text-red-400 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
                  {c}
                </li>
              ))}
            </ul>
          </div>
        </div>
      </div>

      <!-- Sidebar -->
      <div class="space-y-5">
        <!-- Attachments -->
        <div class="bg-bf-surface border border-bf-border rounded-xl p-5">
          <h2 class="font-semibold text-white mb-3 text-sm">Recommended Attachments</h2>
          <ul class="space-y-2">
            {weapon.attachments.map(att => (
              <li class="flex items-center gap-2 text-sm text-gray-300">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-bf-orange" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                {att}
              </li>
            ))}
          </ul>
        </div>

        <!-- More in category -->
        {others.length > 0 && (
          <div class="bg-bf-surface border border-bf-border rounded-xl p-5">
            <h2 class="font-semibold text-white mb-3 text-sm">More {weapon.category}s</h2>
            <ul class="space-y-2">
              {others.map(w => (
                <li>
                  <a href={`/weapons/${w.slug}`} class="flex items-center justify-between text-sm text-gray-300 hover:text-bf-orange transition-colors py-1">
                    <span>{w.name}</span>
                    <span class="text-xs text-gray-500">{w.tier}-Tier</span>
                  </a>
                </li>
              ))}
            </ul>
            <a href="/weapons" class="mt-3 block text-xs text-bf-orange hover:underline">View all weapons →</a>
          </div>
        )}

        <!-- Quick links -->
        <div class="bg-bf-surface border border-bf-border rounded-xl p-5">
          <h2 class="font-semibold text-white mb-3 text-sm">Related Guides</h2>
          <div class="space-y-2">
            <a href="/guides/how-to-play" class="block text-xs text-gray-400 hover:text-bf-orange transition-colors">How to Play Bullet Force</a>
            <a href="/guides/gold-credits" class="block text-xs text-gray-400 hover:text-bf-orange transition-colors">How to Unlock Weapons Fast</a>
            <a href="/maps" class="block text-xs text-gray-400 hover:text-bf-orange transition-colors">Best Weapons Per Map</a>
          </div>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>
