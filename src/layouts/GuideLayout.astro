---
import BaseLayout from './BaseLayout.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import type { BreadcrumbItem } from '../components/Breadcrumb.astro';

interface Props {
  title: string;
  description: string;
  schema?: object | object[];
  breadcrumbs: BreadcrumbItem[];
  toc?: { id: string; label: string }[];
}
const { title, description, schema, breadcrumbs, toc } = Astro.props;
---

<BaseLayout title={title} description={description} schema={schema}>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
    <Breadcrumb items={breadcrumbs} />

    <div class="flex gap-10 items-start">
      <!-- Article -->
      <article class="flex-1 min-w-0 prose-custom max-w-3xl">
        <slot />
      </article>

      <!-- ToC sidebar -->
      {toc && toc.length > 0 && (
        <aside class="hidden xl:block w-60 flex-shrink-0">
          <div class="sticky top-24 bg-bf-surface border border-bf-border rounded-xl p-5">
            <p class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-3">On this page</p>
            <nav>
              <ul class="space-y-2">
                {toc.map(item => (
                  <li>
                    <a href={`#${item.id}`} class="text-sm text-gray-400 hover:text-bf-orange transition-colors block leading-snug">
                      {item.label}
                    </a>
                  </li>
                ))}
              </ul>
            </nav>
          </div>
        </aside>
      )}
    </div>
  </div>
</BaseLayout>
